# Copy this file to .env and fill in your own values.
# .env is gitignored and must never be committed.

# Google AI Studio: https://aistudio.google.com/apikey
# Free tier, no credit card. Used by langchain-google-genai.
GOOGLE_API_KEY=

# LangSmith tracing. Optional: the pipeline runs without these,
# but tracing is how runs are inspected and evaluated.
# Free Developer plan: https://smith.langchain.com
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=cpe-course-agent